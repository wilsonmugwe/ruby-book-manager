<!DOCTYPE html>
<html>
<head>
  <title>Sign Up - Book Manager</title>
  <link rel="stylesheet" href="/style.css">
</head>

<body class="login-page">
  <div class="login-card">
    <h1>Create Account</h1>
    <p class="subtitle">Register a new user account.</p>

    <% if @error %>
      <p class="error-message"><%= @error %></p>
    <% end %>

    <form action="/signup" method="post">
      <label>Username</label>
      <input type="text" name="new_username" placeholder="Choose username">

      <label>Password</label>
      <input type="password" name="new_password" placeholder="Choose password">

      <button type="submit">Sign Up</button>
    </form>

    <div class="auth-links">
      <a href="/login">Back to Login</a>
    </div>
  </div>
</body>
</html>